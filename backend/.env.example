# ═══════════════════════════════════════════════════════════════════════════
# BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════════════════

# ─── SERVER ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ─── DATABASE ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/sabibiz
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sabibiz
DB_USER=postgres
DB_PASSWORD=password
DB_SSL=false

# ─── JWT & SECURITY ─────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=7d
ADMIN_SECRET=your-admin-secret-change-this
VERIFY_TOKEN=biztrack_verify_2024

# ─── SSO & OAUTH ────────────────────────────────────────────────────────────
# Neon Auth (Postgres provider)
NEON_AUTH_ISSUER=https://your-neon-issuer.example
NEON_AUTH_AUDIENCE=your-client-id
NEON_JWKS_URI=https://your-neon-issuer.example/.well-known/jwks.json

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple Sign-In
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# ─── WHATSAPP ───────────────────────────────────────────────────────────────
WHATSAPP_TOKEN=your-whatsapp-business-api-token
PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_CLIENT_ID=your-whatsapp-client-id
WHATSAPP_CLIENT_SECRET=your-whatsapp-client-secret

# ─── PAYMENTS ───────────────────────────────────────────────────────────────
# Paystack
PAYSTACK_SECRET=sk_live_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public-key

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox

# ─── OPENAI & AI ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500

# ─── LOGGING ────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FILE=logs/app.log
SENTRY_DSN=https://your-sentry-dsn@sentry.io/

# ─── RATE LIMITING ──────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── REDIS (OPTIONAL) ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ─── EMAIL (OPTIONAL) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@sabibiz.com

# ─── DEPLOYMENT ─────────────────────────────────────────────────────────────
# Railway
RAILWAY_ENVIRONMENT=development

# ─── FEATURES ───────────────────────────────────────────────────────────────
ENABLE_WHATSAPP=true
ENABLE_AI=true
ENABLE_ANALYTICS=true
ENABLE_AUDIT_LOGS=true
